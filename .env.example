# Cryptic Maze — optional integrations.
# Copy to `.env.local` for local dev, or set these as build-time secrets in CI.
# Every value is OPTIONAL: leave it blank and the related feature simply no-ops.

# --- PostHog product analytics ---
# Project API key (starts with `phc_`). Without it, no analytics are sent.
VITE_POSTHOG_KEY=
# Ingestion host. US cloud is the default; use https://eu.i.posthog.com for EU.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Supabase global stats ---
# Project URL and the *anon* (publishable) key. Both required to enable the
# shared play/solve counts and solve-time distribution. Safe to expose: the
# anon key can only call the locked-down RPCs in supabase/schema.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
